	<!--                     VANILLA VEHICLES                         -->
	<!-- ============================================================ -->

	<!-- Bicycle | HP: 1500 → 2000 | Self-damage: -15% -->
	<set xpath="/items/item[@name='vehicleBicyclePlaceable']/effect_group[@name='vehicleBicyclePlaceable']/passive_effect[@name='DegradationMax']/@value">2000</set>
	<append xpath="/items/item[@name='vehicleBicyclePlaceable']/effect_group[@name='vehicleBicyclePlaceable']">
		<passive_effect name="VehicleSelfDamage" operation="perc_add" value="-.15" tags="vehicle"/>
